              },
              {
                "key": "Authorization",
                "value": "Bearer {{enrollment_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"enrollment_created\",\n  \"event_id\": \"{{enrollment_event_id}}\",\n  \"agent_id\": \"{{current_agent_id}}\",\n  \"agent_email\": \"{{current_agent_email}}\",\n  \"enrollment_count\": 5,\n  \"timestamp\": \"{{event_timestamp}}\",\n  \"signature\": \"{{enrollment_signature}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "insurance-events"]
            },
            "description": "Send multiple enrollments in a single event (e.g., batch enrollment)\n\nThe enrollment_count field can be any number >= 1"
          }
        }
      ]
