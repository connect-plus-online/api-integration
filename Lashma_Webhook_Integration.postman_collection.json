  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global webhook signing to keep all requests consistent",
          "const crypto = require('crypto');",
          "",
          "if ((pm.request.method || '').toUpperCase() !== 'POST') {",
          "  return;",
          "}",
          "",
          "// Keep the explicit invalid-signature test untouched",
          "if ((pm.info && pm.info.requestName) === 'Test: Invalid Signature (Should fail with 401)') {",
          "  return;",
          "}",
          "",
          "const secret = pm.environment.get('webhook_secret');",
          "if (!secret) {",
          "  console.warn('webhook_secret is not set; signature cannot be generated.');",
          "  return;",
          "}",
          "",
          "// Ensure commonly used variables always exist",
          "pm.environment.set('current_agent_id', pm.environment.get('agent_id') || 'agent_uuid_test');",
          "pm.environment.set('current_agent_email', pm.environment.get('agent_email') || 'test@lashma.com');",
          "if (!pm.environment.get('event_timestamp')) {",
          "  pm.environment.set('event_timestamp', new Date().toISOString());",
          "}",
          "",
          "const method = (pm.request.method || 'POST').toUpperCase();",
          "const uri = '/' + (pm.request.url.path || []).join('/');",
          "const rawBody = pm.variables.replaceIn(pm.request.body && pm.request.body.raw ? pm.request.body.raw : '');",
          "",
          "let bodyForSignature = rawBody;",
          "let eventType = '';",
          "try {",
          "  const parsed = JSON.parse(rawBody || '{}');",
          "  if (parsed && typeof parsed === 'object') {",
          "    eventType = parsed.event_type || '';",
          "    delete parsed.signature;",
          "    bodyForSignature = JSON.stringify(parsed);",
          "  }",
          "} catch (error) {",
          "  console.warn('Unable to parse request body for signature generation:', error.message);",
          "}",
          "",
          "const payload = method + uri + bodyForSignature;",
          "const signature = crypto.createHmac('sha256', secret).update(payload).digest('hex');",
          "",
          "pm.environment.set('webhook_signature', signature);",
          "if (eventType === 'enrollment_created') pm.environment.set('enrollment_signature', signature);",
          "if (eventType === 'payment_processed') pm.environment.set('payment_signature', signature);",
          "if (eventType === 'payment_status_updated') pm.environment.set('payment_status_signature', signature);",
          "",
          "pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${signature}` });",
          "console.log(`Generated signature for ${eventType || 'webhook'}: ${signature.substring(0, 16)}...`);"
        ]
      }
    },
