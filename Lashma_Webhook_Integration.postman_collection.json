    {
      "name": "Payment Status Update Events",
      "item": [
        {
          "name": "Update Payment Status: Pending → Completed",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate new event ID (but use same payment ID as before)",
                  "const timestamp = new Date().toISOString().replace(/[^0-9]/g, '').slice(0, 14);",
                  "const sequence = Math.floor(Math.random() * 10000);",
                  "const updateEventId = `evt_${timestamp}_update_${sequence}`;",
                  "pm.environment.set('update_event_id', updateEventId);",
                  "",
                  "// Can use saved payment_id from previous request or create new one",
                  "let paymentId = pm.environment.get('payment_id');",
                  "if (!paymentId) {",
                  "  paymentId = `pay_${timestamp}_TXN_${sequence}`;",
                  "}",
                  "pm.environment.set('update_payment_id', paymentId);",
                  "",
                  "const isoTimestamp = new Date().toISOString();",
                  "pm.environment.set('event_timestamp', isoTimestamp);",
                  "",
                  "console.log('Update Event ID:', updateEventId);",
                  "console.log('Payment ID:', paymentId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  console.log('✓ Payment status update sent successfully');",
                  "  console.log('Payment:', pm.environment.get('update_payment_id'));",
                  "  console.log('Status: pending → completed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{payment_status_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"payment_status_updated\",\n  \"event_id\": \"{{update_event_id}}\",\n  \"agent_id\": \"{{current_agent_id}}\",\n  \"agent_email\": \"{{current_agent_email}}\",\n  \"payment_id\": \"{{update_payment_id}}\",\n  \"previous_status\": \"pending\",\n  \"current_status\": \"completed\",\n  \"failure_reason\": null,\n  \"timestamp\": \"{{event_timestamp}}\",\n  \"signature\": \"{{payment_status_signature}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "insurance-events"]
            },
            "description": "Send payment status update event\n\nUse the SAME payment_id from the original payment_processed event\nChange the previous_status and current_status fields as needed"
          }
        },
