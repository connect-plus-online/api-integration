{
  "info": {
    "_postman_id": "lashma-webhook-integration-v2",
    "name": "Lashma Webhook Integration (No HMAC, Policy-based)",
    "description": "Webhook testing collection for refactored insurance-events endpoint. Uses agent_email + policy_numbers and no signature auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Enrollment Events",
      "item": [
        {
          "name": "Enrollment Created - Count matches policies",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date().toISOString();",
                  "const rand = Math.floor(Math.random()*100000);",
                  "pm.environment.set('event_timestamp', now);",
                  "pm.environment.set('event_id', `evt_enroll_${Date.now()}_${rand}`);",
                  "pm.environment.set('policy_1', `LSHS-PM-${Date.now()}-1`);",
                  "pm.environment.set('policy_2', `LSHS-PM-${Date.now()}-2`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"enrollment_created\",\n  \"event_id\": \"{{event_id}}\",\n  \"agent_email\": \"{{agent_email}}\",\n  \"enrollment_count\": 2,\n  \"policy_numbers\": [\"{{policy_1}}\", \"{{policy_2}}\"],\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        },
        {
          "name": "Enrollment Created - Count mismatch (allowed)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('event_timestamp', new Date().toISOString());",
                  "pm.environment.set('event_id', `evt_enroll_mismatch_${Date.now()}`);",
                  "pm.environment.set('policy_1', `LSHS-MISMATCH-${Date.now()}-1`);",
                  "pm.environment.set('policy_2', `LSHS-MISMATCH-${Date.now()}-2`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"enrollment_created\",\n  \"event_id\": \"{{event_id}}\",\n  \"agent_email\": \"{{agent_email}}\",\n  \"enrollment_count\": 5,\n  \"policy_numbers\": [\"{{policy_1}}\", \"{{policy_2}}\"],\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payment Events",
      "item": [
        {
          "name": "Payment Processed - Completed (uses enrolled policies)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('event_timestamp', new Date().toISOString());",
                  "pm.environment.set('event_id', `evt_pay_${Date.now()}`);",
                  "pm.environment.set('payment_id', `pay_${Date.now()}`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"payment_processed\",\n  \"event_id\": \"{{event_id}}\",\n  \"policy_numbers\": [\"{{policy_1}}\", \"{{policy_2}}\"],\n  \"payment_id\": \"{{payment_id}}\",\n  \"payment_status\": \"completed\",\n  \"payment_type\": \"recurring\",\n  \"amount\": 25000,\n  \"currency\": \"NGN\",\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        },
        {
          "name": "Payment Processed - Different-agent policies",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('event_timestamp', new Date().toISOString());",
                  "pm.environment.set('event_id', `evt_pay_cross_${Date.now()}`);",
                  "pm.environment.set('payment_id', `pay_cross_${Date.now()}`);",
                  "if (!pm.environment.get('cross_policy_a')) pm.environment.set('cross_policy_a', 'LSHS-CROSS-A-1');",
                  "if (!pm.environment.get('cross_policy_b')) pm.environment.set('cross_policy_b', 'LSHS-CROSS-B-1');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"payment_processed\",\n  \"event_id\": \"{{event_id}}\",\n  \"policy_numbers\": [\"{{cross_policy_a}}\", \"{{cross_policy_b}}\"],\n  \"payment_id\": \"{{payment_id}}\",\n  \"payment_status\": \"completed\",\n  \"payment_type\": \"recurring\",\n  \"amount\": 25000,\n  \"currency\": \"NGN\",\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payment Status Update",
      "item": [
        {
          "name": "Payment Status Updated",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('event_timestamp', new Date().toISOString());",
                  "pm.environment.set('event_id', `evt_status_${Date.now()}`);",
                  "if (!pm.environment.get('payment_id')) pm.environment.set('payment_id', `pay_${Date.now()}`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"payment_status_updated\",\n  \"event_id\": \"{{event_id}}\",\n  \"payment_id\": \"{{payment_id}}\",\n  \"previous_status\": \"pending\",\n  \"current_status\": \"completed\",\n  \"failure_reason\": null,\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Edge Cases",
      "item": [
        {
          "name": "Agent Not Found",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('event_timestamp', new Date().toISOString());",
                  "pm.environment.set('event_id', `evt_notfound_${Date.now()}`);",
                  "pm.environment.set('missing_agent_email', `missing.agent.${Date.now()}@example.com`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"enrollment_created\",\n  \"event_id\": \"{{event_id}}\",\n  \"agent_email\": \"{{missing_agent_email}}\",\n  \"enrollment_count\": 1,\n  \"policy_numbers\": [\"LSHS-NOTFOUND-1\"],\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        },
        {
          "name": "Unsupported Event Type (400)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('event_timestamp', new Date().toISOString());",
                  "pm.environment.set('event_id', `evt_badtype_${Date.now()}`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"not_a_real_event\",\n  \"event_id\": \"{{event_id}}\",\n  \"timestamp\": \"{{event_timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "webhooks",
                "insurance-events"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4040",
      "type": "string"
    },
    {
      "key": "agent_email",
      "value": "dagogodboss@coms.com",
      "type": "string"
    },
    {
      "key": "event_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "event_timestamp",
      "value": "",
      "type": "string"
    },
    {
      "key": "policy_1",
      "value": "",
      "type": "string"
    },
    {
      "key": "policy_2",
      "value": "",
      "type": "string"
    },
    {
      "key": "cross_policy_a",
      "value": "LSHS-CROSS-A-1",
      "type": "string"
    },
    {
      "key": "cross_policy_b",
      "value": "LSHS-CROSS-B-1",
      "type": "string"
    },
    {
      "key": "payment_id",
      "value": "",
      "type": "string"
    }
  ]
}