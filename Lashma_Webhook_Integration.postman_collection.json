    {
      "name": "Payment Events",
      "item": [
        {
          "name": "Send Payment Processed (Completed)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate unique event and payment IDs",
                  "const timestamp = new Date().toISOString().replace(/[^0-9]/g, '').slice(0, 14);",
                  "const sequence = Math.floor(Math.random() * 10000);",
                  "const eventId = `evt_${timestamp}_payment_${sequence}`;",
                  "const paymentId = `pay_${timestamp}_TXN_${sequence}`;",
                  "pm.environment.set('payment_event_id', eventId);",
                  "pm.environment.set('payment_id', paymentId);",
                  "",
                  "// Get current ISO timestamp",
                  "const isoTimestamp = new Date().toISOString();",
                  "pm.environment.set('event_timestamp', isoTimestamp);",
                  "",
                  "// Get environment variables",
                  "const secret = pm.environment.get('webhook_secret');",
                  "const agentId = pm.environment.get('agent_id') || 'agent_uuid_test';",
                  "const agentEmail = pm.environment.get('agent_email') || 'test@lashma.com';",
                  "pm.environment.set('current_agent_id', agentId);",
                  "pm.environment.set('current_agent_email', agentEmail);",
                  "pm.environment.set('payment_status', 'completed');",
                  "pm.environment.set('payment_type', 'recurring');",
                  "pm.environment.set('payment_amount', 25000);",
                  "",
                  "// Build request body (compact JSON, no spaces, no signature field)",
                  "const body = JSON.stringify({",
                  "  event_type: 'payment_processed',",
                  "  event_id: eventId,",
                  "  agent_id: agentId,",
                  "  agent_email: agentEmail,",
                  "  payment_id: paymentId,",
                  "  payment_status: 'completed',",
                  "  payment_type: 'recurring',",
                  "  amount: 25000,",
                  "  currency: 'NGN',",
                  "  timestamp: isoTimestamp",
                  "});",
                  "",
                  "// Calculate HMAC-SHA256 signature",
                  "const crypto = require('crypto');",
                  "const method = 'POST';",
                  "const uri = '/api/webhooks/insurance-events';",
                  "const payload = method + uri + body;",
                  "const signature = crypto.createHmac('sha256', secret).update(payload).digest('hex');",
                  "pm.environment.set('payment_signature', signature);",
                  "",
                  "console.log('Event ID:', eventId);",
                  "console.log('Payment ID:', paymentId);",
                  "console.log('Signature:', signature.substring(0, 16) + '...');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "  console.log('✓ Payment processed event sent successfully');",
                  "  console.log('Payment ID:', pm.environment.get('payment_id'));",
                  "  console.log('Status:', pm.environment.get('payment_status'));",
                  "  console.log('Amount:', pm.environment.get('payment_amount'), 'kobo');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{payment_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"payment_processed\",\n  \"event_id\": \"{{payment_event_id}}\",\n  \"agent_id\": \"{{current_agent_id}}\",\n  \"agent_email\": \"{{current_agent_email}}\",\n  \"payment_id\": \"{{payment_id}}\",\n  \"payment_status\": \"{{payment_status}}\",\n  \"payment_type\": \"{{payment_type}}\",\n  \"amount\": {{payment_amount}},\n  \"currency\": \"NGN\",\n  \"timestamp\": \"{{event_timestamp}}\",\n  \"signature\": \"{{payment_signature}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/insurance-events",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "insurance-events"]
            },
            "description": "Send payment processed event with completed status\n\nStatus options: pending, completed, failed, refunded"
          }
        },
